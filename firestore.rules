rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the current user is the hardcoded admin
    function isHardcodedAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "viettri0005@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    // Helper to check if the current user has a specific role
    function hasRole(role) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isHardcodedAdmin() || hasRole('owner');
    }

    function isManager() {
      return isAdmin() || hasRole('barista');
    }

    function isValidUser(data) {
      return data.role in ['employee', 'barista', 'owner'] &&
             data.status in ['pending', 'approved', 'inactive'] &&
             data.email is string &&
             data.uid is string &&
             data.displayName is string;
    }

    match /users/{userId} {
      // CRITICAL: Ownership check MUST come first to break circularity
      allow read: if isAuthenticated() && (request.auth.uid == userId || isManager());
      
      // Allow users to create their own profile during registration/request
      // Or allow admins to manage users
      allow create: if isAuthenticated() && (
        (request.auth.uid == userId && (
          // Case 1: Hardcoded admin creates their own approved owner profile
          (isHardcodedAdmin() && request.resource.data.role == "owner" && request.resource.data.status == "approved") ||
          // Case 2: Any other user creates their own pending employee profile
          (!isHardcodedAdmin() && request.resource.data.role == "employee" && request.resource.data.status == "pending")
        )) || 
        isAdmin()
      );
      
      // Users can update their own non-sensitive info, admins can update everything
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.status == resource.data.status) || 
        isAdmin()
      );
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['paid'])) || 
        isManager()
      );
      allow delete: if isManager();
    }

    match /counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    match /dailySales/{date} {
      allow read, write: if isManager();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
