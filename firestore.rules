rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the current user is the hardcoded admin
    function isHardcodedAdmin() {
      return isAuthenticated() && request.auth.token.email == "viettri0005@gmail.com";
    }

    // Helper to check if the current user has a specific role
    function hasRole(role) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isHardcodedAdmin() || hasRole('owner');
    }

    function isManager() {
      return isAdmin() || hasRole('barista');
    }

    match /users/{userId} {
      // CRITICAL: Ownership check MUST come first to break circularity when hasRole() or isManager() is called
      allow read: if isAuthenticated() && (request.auth.uid == userId || isManager());
      
      // Only admins can create/update roles, but users can update their own non-role info
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['paid'])) || 
        isManager()
      );
      allow delete: if isManager();
    }

    match /counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    match /dailySales/{date} {
      allow read, write: if isManager();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
